# --- General Bot Settings ---
BOT_NAME=reply_bot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# --- MongoDB Settings ---
MONGO_URI=mongodb://mongo:27017/
MONGO_DB_NAME=reply_db

# --- Redis Settings ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1 # Use a different DB than club_entrance_bot if running on the same Redis instance
# REDIS_QUEUE_NAME=reply_bot_queue # If using Redis queue for other purposes

# --- Web Admin Settings ---
WEB_PORT=8071 # Use a different port than club_entrance_bot
WEB_USERNAME=admin
WEB_PASSWORD=password
WEB_BASE_URL=http://localhost:8071 # Base URL for the web admin interface

# --- Ask Naboka Bot Specific ---
# Comma-separated list of Telegram User IDs for master users who receive notifications
MASTER_USER_IDS=12345678,98765432

# --- Queue for broadcast messages from admin panel ---
BROADCAST_QUEUE_NAME=reply_bot_broadcast_queue

# --- Optional: Target Chat for Invites (if questionnaire functionality is restored) ---
# TARGET_CHAT_ID=YOUR_TARGET_TELEGRAM_CHAT_ID
